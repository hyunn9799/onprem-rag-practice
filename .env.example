# ---- OpenSearch (BM25 / 키워드 검색) ----
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX=rag_chunks
# nori(한국어 형태소, 기본) | standard. nori 는 analysis-nori 포함 이미지 필요(compose 가 빌드)
OPENSEARCH_ANALYZER=nori
# RECREATE_INDEX=true   # analyzer 를 바꿨을 때 1회 켜서 index 재생성(재적재 필요)

# ---- Milvus (Vector DB) ----
# Docker standalone 사용 → 서버 주소. (파일모드 Milvus Lite 는 ./milvus_rag.db)
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=rag_chunks

# ---- 임베딩 / 리랭커 (별도 TEI 컨테이너, 앱은 HTTP 호출) ----
# 분리 모드: 노트북=DB만(make up-db), T4=모델만(make up-models-gpu).
# Lightning 에서 포트 8080/8081 을 공개하면 아래처럼 원격 URL 로 교체:
#   EMBEDDING_API_URL=https://8080-<studio-id>.cloudspaces.litng.ai
#   RERANKER_API_URL=https://8081-<studio-id>.cloudspaces.litng.ai
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_API_URL=http://localhost:8080
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_API_URL=http://localhost:8081
USE_RERANKER=true

# ---- LLM ----
# LLM_PROVIDER=local  → 로컬 vLLM(OpenAI 호환). LLM_BASE_URL 사용.
# LLM_PROVIDER=openai → OpenAI. OPENAI_API_KEY 필수. (T4 메모리 빠듯할 때 이 경로)
LLM_PROVIDER=local
LLM_MODEL=skt/A.X-4.0-Light
LLM_BASE_URL=http://localhost:8001/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---- (선택) 게이티드 모델 다운로드용 HF 토큰 ----
HF_TOKEN=

# ---- Retrieval knobs ----
BM25_TOP_K=20
VECTOR_TOP_K=20
RRF_K=60
FINAL_TOP_K=5
